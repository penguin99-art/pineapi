# Pinea Model Gateway 配置（复制为 .env，按需改）。前缀 PINEA_。

# 网关监听（默认只监听本机；外放到 LAN/WAN 时必须配置 PINEA_API_KEY）
PINEA_HOST=127.0.0.1
PINEA_PORT=18800

# 设备安全门锁。留空 = 不校验（仅限本机封闭部署/开发）。
PINEA_API_KEY=

# ① 文本/视觉/embed 后端：本机 ollama（OpenAI 兼容）
PINEA_OLLAMA_URL=http://localhost:11434

# 默认文本模型（/v1/chat 不传 model 时用）
PINEA_DEFAULT_CHAT_MODEL=gpt-oss:20b
